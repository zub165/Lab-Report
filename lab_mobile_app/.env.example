# Copy to `.env` and fill in real values. Never commit `.env`.
# cp .env.example .env
#
# The Flutter app does not load this file automatically yet.
# Use these values in Django Admin, login screen, android/key.properties, and MySQL.

# --- Display currency: PKR, USD, EUR, GBP, AED, SAR, INR, CAD ---
DISPLAY_CURRENCY=PKR

# --- Lab API only (must end with /lab/) — NOT https://api.mywaitime.com/api/ ---
LAB_API_BASE_URL=https://api.mywaitime.com/lab
LAB_API_BASE_BACKUP=http://208.109.215.53:3015/lab
SAEEDLAB_WEB_URL=https://zub165.github.io/SaeedLab/

# --- Lab superuser (add staff, Django admin, mobile "Sign in as Admin") ---
LAB_ADMIN_USERNAME=admin
LAB_ADMIN_PASSWORD=change_me
LAB_ADMIN_USER_ID=1

# --- Demo accounts (production API) ---
LAB_DEMO_DOCTOR_USERNAME=labdoctor
LAB_DEMO_DOCTOR_PASSWORD=labdoctor123

# --- Optional / legacy (may not exist on production API) ---
LAB_SAIED_ADMIN_USERNAME=saied_admin
LAB_SAIED_ADMIN_PASSWORD=change_me

# --- Default password suggested when creating new staff in the app ---
LAB_STAFF_DEFAULT_PASSWORD=Staff@2026

# --- MySQL (Node legacy / Medi_Lab — parent repo server, not Flutter UI) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=Medi_Lab
DB_SSL=false

# --- Node server (reference React app) ---
PORT=3003
NODE_ENV=development
DJANGO_INTERNAL_URL=http://127.0.0.1:3015
ALLOWED_ORIGINS=http://localhost:3003,http://127.0.0.1:3003

# --- Android release signing (also copy to android/key.properties) ---
ANDROID_KEYSTORE_PATH=/path/to/upload-keystore.jks
ANDROID_KEYSTORE_PASSWORD=change_me
ANDROID_KEY_PASSWORD=change_me
ANDROID_KEY_ALIAS=upload

# --- Stripe publishable only (pk_test_ / pk_live_; never sk_ or whsec_) ---
# Per-lab: Settings → Laboratory Information. Dev fallback below:
STRIPE_PUBLISHABLE_KEY=
STRIPE_PUBLISHABLE_KEY_BACKUP=pk_test_your_key_here

# --- Mobile: in-app subscription (App Store + Google Play only) ---
LAB_SUBSCRIPTION_PRODUCT_ID=com.mywaitime.lab.monthly

# --- Support / legal ---
LAB_SUPPORT_EMAIL=support@saeedlab.com
LAB_SUPPORT_EMAIL_ALT=zub165@yahoo.com
